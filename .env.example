PORT=4300
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/interesthub
# Optional for Docker Compose when using Atlas or another external MongoDB.
# DOCKER_MONGO_URI=mongodb+srv://username:password@cluster/interesthub
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:4300
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
EMAIL_ENABLED=false
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=InterestHub <no-reply@example.com>
CONTACT_TO_EMAIL=
LOG_LEVEL=http
